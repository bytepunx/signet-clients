{
  "name": "@bytepunx/signet-client",
  "version": "0.2.0",
  "description": "TypeScript/Node client for signet, generated from bytepunx/signet-proto",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p examples/echo/tsconfig.json",
    "test": "node --test dist/**/*.test.js"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.0.0",
    "@grpc/grpc-js": "^1.10.0",
    "spiffe": "^0.5.1"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  }
}
