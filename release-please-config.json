{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "separate-pull-requests": true,
  "packages": {
    "go": {
      "release-type": "go",
      "component": "go",
      "tag-separator": "/"
    },
    "python": {
      "release-type": "python",
      "component": "python"
    },
    "typescript": {
      "release-type": "node",
      "component": "typescript"
    },
    "rust": {
      "release-type": "rust",
      "component": "rust"
    },
    "csharp": {
      "release-type": "simple",
      "component": "csharp",
      "extra-files": [
        {
          "type": "xml",
          "path": "SignetClient.csproj",
          "xpath": "//Version"
        }
      ]
    }
  }
}
